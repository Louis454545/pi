{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@earendil-works/morgan-ai": ["./packages/ai/src/index.ts"],
			"@earendil-works/morgan-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@earendil-works/morgan-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@earendil-works/morgan-ai/dist/*": ["./packages/ai/src/*"],
			"@earendil-works/morgan-agent-core": ["./packages/agent/src/index.ts"],
			"@earendil-works/morgan-agent-core/*": ["./packages/agent/src/*"],
			"@earendil-works/morgan-agent": ["./packages/morgan-agent/src/index.ts"],
			"@earendil-works/morgan-agent/hooks": ["./packages/morgan-agent/src/core/hooks/index.ts"],
			"@earendil-works/morgan-agent/schedules": ["./packages/morgan-agent/src/schedules.ts"],
			"@earendil-works/morgan-agent/*": ["./packages/morgan-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@earendil-works/morgan-tui": ["./packages/tui/src/index.ts"],
			"@earendil-works/morgan-tui/*": ["./packages/tui/src/*"],
			"@earendil-works/morgan-agent-old": ["./packages/agent-old/src/index.ts"],
			"@earendil-works/morgan-agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/morgan-agent/examples/**/*"],
	"exclude": ["**/dist/**", "packages/morgan-agent/examples/extensions/gondolin/**"]
}
